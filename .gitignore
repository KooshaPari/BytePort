**/config/local.yaml
**/config/*.local.yaml
**/config/production.yaml

# Generated by Cargo
# will have compiled files and executables
debug/
target/

# include cargo lock
!Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

*.sqlite

# BytePort build outputs (Scorecard BinaryArtifacts FP cleanup)
backend/byteport/tmp/
byteport
.history/

# Certificate / key files (sensitive)
*.pem
*.key
*.cert

# Database state files (local, not for sharing)
backend/database.db

# Stale root lockfile (no package.json in root)
/package-lock.json

# macOS metadata
.DS_Store

# Generated text/binary artifacts
backend/out.tt
backend/nvms/tmp/
backend/byteport/log.txt
backend/nvms/log.txt
backend/byteport/byteport
backend/nvms/spin
