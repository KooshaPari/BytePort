**/config/local.yaml
**/config/*.local.yaml
**/config/production.yaml

# Generated by Cargo
# will have compiled files and executables
debug/
target/

# include cargo lock
!Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

*.sqlite

# BytePort build outputs (Scorecard BinaryArtifacts FP cleanup)
backend/byteport/tmp/
byteport
.history/

# ===== Standard auto-generated hygiene ignores (do not edit manually) =====
.DS_Store
.env
.env.*
!.env.example
node_modules/
dist/
build/
coverage/
.pytest_cache/
__pycache__/
.mypy_cache/
.ruff_cache/
.venv/
venv/
# ===== End standard hygiene ignores =====
