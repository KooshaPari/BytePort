{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "byteport-desktop",
  "description": "Permissions for the BytePort desktop UI. Exposes only the byteport: namespace and minimum core permissions. Does not include arbitrary shell/exec/process permissions.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "core:menu:default",
    "core:tray:default",
    "os:default",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    {
      "identifier": "core:window:allow-set-title",
      "allow": [{ "label": "main" }]
    }
  ]
}
